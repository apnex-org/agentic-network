# CloudRun plan variables — Architect service + IAM.
#
# mission-86 retired the Hub-on-Cloud-Run service from this plan; the Hub
# now runs on the deploy/hub/ VM. This plan deploys the Architect service.
#
# Requires the base plan in deploy/base/ to be applied first.
# Reads service_account_email, state_bucket_name, registry_prefix
# from deploy/base/terraform.tfstate via terraform_remote_state.
#
# Copy to `<env-name>.tfvars` and fill in values. Do NOT commit `<env>.tfvars`
# (excluded by deploy/.gitignore: env/*.tfvars).
#
# Per-env tfvars convention (mission-46 T1):
#   deploy/cloudrun/env/prod.tfvars        (the original env)
#   deploy/cloudrun/env/<other-env>.tfvars (new isolated tenants)
# Select with OIS_ENV=<env-name> (default: prod if unset).

# ── Required per-env ─────────────────────────────────────────────────

project_id                   = "<your-gcp-project-id>"
region                       = "<your-gcp-region>"

# ── Secrets (DO NOT commit real values) ──────────────────────────────

# Bearer token the Architect uses to authenticate to the Hub.
hub_api_token                = "<generate-with-openssl-rand-base64-32>"

# Stable agent identity (Mission-18).
# Generate once per env: uuidgen
# Changing this creates a new Agent entity and orphans the old queue.
architect_global_instance_id = "<uuidgen-output>"

# ── Hub endpoint ─────────────────────────────────────────────────────
#
# The Architect's Hub MCP endpoint — the deploy/hub/ Cloud Run proxy URL
# + /mcp. Leave empty until the deploy/hub/ plan is applied.
#
# hub_mcp_url = "https://hub-api-<hash>.a.run.app/mcp"

# ── Per-env service name (mission-46 T1 convention) ──────────────────
#
# The Cloud Run service name can carry an env suffix so multiple envs
# coexist in one GCP project. Default is "architect-agent".
#
# architect_service_name = "architect-<env-name>"

# ── Other knobs ──────────────────────────────────────────────────────
#
# Most other vars use variables.tf defaults (architect_min_instances=1,
# event_loop_enabled=true, event_loop_interval=300, ...) — override here
# if env-specific.
