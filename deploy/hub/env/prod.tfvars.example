# deploy/hub/ root-caller variables — mission-86's deployment of modules/hub/.
#
# Copy to env/<env>.tfvars and fill in. Do NOT commit env/<env>.tfvars
# (gitignored by deploy/.gitignore: env/*.tfvars).
#
# A second hub deployment = another thin root caller with its own tfvars
# pointing `source` at ../../modules/hub.

project_id             = "labops-389703"
region                 = "australia-southeast1"
zone                   = "australia-southeast1-a"
name_prefix            = "hub"
environment            = "prod"

hub_image              = "australia-southeast1-docker.pkg.dev/labops-389703/cloud-run-source-deploy/hub:latest"
proxy_image            = "australia-southeast1-docker.pkg.dev/labops-389703/cloud-run-source-deploy/hub-proxy:latest"

# postgres + watchtower: Docker Hub images pulled via the AR pull-through
# remote (the internal-only VM cannot reach Docker Hub directly).
postgres_image         = "australia-southeast1-docker.pkg.dev/labops-389703/hub-dockerhub-remote/library/postgres:15-alpine"
watchtower_image       = "australia-southeast1-docker.pkg.dev/labops-389703/hub-dockerhub-remote/containrrr/watchtower:latest"

artifact_registry_repo = "cloud-run-source-deploy"

source_repo_url        = "https://github.com/apnex-org/agentic-network"
source_repo_branch     = "main"

backup_bucket_name     = "labops-389703-hub-backups"

# Cloud Build webhook trigger — false until finding F9 (opaque 400) is diagnosed.
enable_cloudbuild_trigger = false

# W3 F11 — cloud-Hub repo-event-bridge.
# gh_api_token: a GitHub PAT with repo / read:org / read:user scopes —
# provisioned into Secret Manager + surfaced to the Hub container. SENSITIVE;
# set in env/<env>.tfvars (gitignored), never here.
gh_api_token            = "ghp_REPLACE_WITH_A_REAL_PAT"
repo_event_bridge_repos = "apnex-org/agentic-network"
