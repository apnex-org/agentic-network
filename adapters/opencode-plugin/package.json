{
  "name": "@apnex/opencode-plugin",
  "version": "0.2.0",
  "description": "OpenCode host bundle — Universal Agent Adapter for the OIS agentic network (GPT-5.5/OpenCode peer)",
  "license": "MIT",
  "type": "module",
  "main": "dist/shim.js",
  "files": [
    "dist/",
    "src/",
    "test/",
    "tsconfig.json",
    "QUICKSTART.md",
    "AGENTS.md"
  ],
  "scripts": {
    "prebuild": "node ../../scripts/build/write-build-info.js",
    "build": "tsc",
    "bundle": "node ../../scripts/build/bundle-opencode.js",
    "start": "node dist/shim.js",
    "dev": "tsx src/shim.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@apnex/cognitive-layer": "*",
    "@apnex/message-router": "*",
    "@apnex/network-adapter": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "~1.3.15",
    "@opencode-ai/sdk": "~1.3.15",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
