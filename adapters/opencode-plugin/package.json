{
  "name": "@apnex/opencode-plugin",
  "version": "0.1.0",
  "description": "OpenCode host bundle — Universal Agent Adapter for the OIS agentic network (GPT-5.5/OpenCode peer)",
  "license": "MIT",
  "type": "module",
  "main": "dist/shim.js",
  "files": [
    "dist/",
    "src/",
    "test/",
    "tsconfig.json",
    "QUICKSTART.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/shim.ts --bundle --platform=node --format=esm --outfile=dist/shim.js --external:@opencode-ai/plugin --alias:@apnex/cognitive-layer=../../packages/cognitive-layer/src/index.ts --alias:@apnex/message-router=../../packages/message-router/src/index.ts --alias:@apnex/network-adapter=../../packages/network-adapter/src/index.ts",
    "start": "node dist/shim.js",
    "dev": "tsx src/shim.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@apnex/cognitive-layer": "*",
    "@apnex/message-router": "*",
    "@apnex/network-adapter": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "~1.3.6",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
