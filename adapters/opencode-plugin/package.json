{
  "name": "@apnex/opencode-plugin",
  "version": "0.2.3",
  "description": "OpenCode host plugin — Universal Agent Adapter for the OIS agentic network (npm graph-published package)",
  "license": "MIT",
  "type": "module",
  "main": "dist/plugin-entry.js",
  "files": [
    "dist/",
    "src/",
    "tsconfig.json",
    "QUICKSTART.md",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "scripts": {
    "prebuild": "node ../../scripts/build/write-build-info.js",
    "build": "tsc",
    "prepack": "node ../../scripts/build/write-build-info.js --assert",
    "start": "node dist/plugin-entry.js",
    "dev": "tsx src/shim.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@apnex/network-adapter": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "~1.3.15",
    "@opencode-ai/sdk": "~1.3.15",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "types": "dist/plugin-entry.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin-entry.d.ts",
      "import": "./dist/plugin-entry.js"
    },
    "./shim": {
      "types": "./dist/shim.d.ts",
      "import": "./dist/shim.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "opencode-plugin",
    "opencode",
    "mcp",
    "ois",
    "agentic-network"
  ]
}
