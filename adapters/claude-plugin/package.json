{
  "name": "@apnex/claude-plugin",
  "version": "0.1.13",
  "description": "Claude Code host bundle \u2014 Universal Agent Adapter for the OIS agentic network",
  "license": "MIT",
  "type": "module",
  "main": "dist/shim.js",
  "files": [
    "dist/",
    "agent-adapter.manifest.json",
    ".claude-plugin/",
    ".mcp.json",
    "install.sh",
    "QUICKSTART.md",
    "tsconfig.json",
    "src/",
    "test/",
    "lib/",
    "skills/"
  ],
  "scripts": {
    "prebuild": "node ../../scripts/build/write-build-info.js",
    "build": "tsc",
    "prepack": "node ../../scripts/build/write-build-info.js --assert && node ../../scripts/build/stage-skills.js",
    "start": "node dist/shim.js",
    "dev": "tsx src/shim.ts",
    "test": "vitest run",
    "postpack": "node ../../scripts/build/stage-skills.js --clean"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@apnex/network-adapter": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
