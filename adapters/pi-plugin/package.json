{
  "name": "@apnex/pi-plugin",
  "version": "0.1.9",
  "description": "pi host extension — Universal Agent Adapter for the OIS agentic network (architect peer; reference implementation of the sovereign tool-manager + native-binding architecture)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "dist/index.js"
    ]
  },
  "files": [
    "dist/",
    "agent-adapter.manifest.json",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "node ../../scripts/build/build-self-contained-plugin.mjs pi",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {},
  "peerDependencies": {
    "@earendil-works/pi-tui": "0.81.1",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.81.1",
    "@earendil-works/pi-tui": "0.81.1",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typebox": "1.1.38",
    "vitest": "^4.1.4"
  },
  "bin": {
    "ois-seed-skills": "dist/seed-skills.js"
  }
}
