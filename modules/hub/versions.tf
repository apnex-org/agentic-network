# modules/hub/ — provider version constraints only.
# Provider + backend config live in the deploy/hub/ root caller
# (Design v1.3 §4.1 discipline #3); this module declares constraints.

terraform {
  required_version = ">= 1.5"

  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 6.0"
    }
    github = {
      source  = "integrations/github"
      version = "~> 6.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }
}
