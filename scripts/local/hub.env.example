# hub.env — local-Hub tooling configuration
#
# Copy this file to ~/.config/apnex-agents/hub.env and populate it:
#
#   mkdir -p ~/.config/apnex-agents
#   cp scripts/local/hub.env.example ~/.config/apnex-agents/hub.env
#   $EDITOR ~/.config/apnex-agents/hub.env
#
# scripts/local/start-hub.sh and scripts/local/build-hub.sh source this
# file (key=value, shell-sourced) — the single config source for the
# local-Hub tooling. It lives under ~/.config (outside the repo), so
# secrets never sit in the working tree.
#
# mission-87 W1 (idea-308): this replaces the former per-env
# deploy/{cloudrun,base}/env/*.tfvars HCL config — those Cloud Run
# terraform roots were removed; their tfvars no longer fed terraform,
# so the config moved here, the convention sibling scripts (get-agents.sh,
# publish-packages.sh) already use.

# ── Required ───────────────────────────────────────────────────────────

# Hub API bearer token (secret). Consumed by start-hub.sh.
HUB_API_TOKEN="your-secret-token-here"

# GCP project id. Consumed by build-hub.sh (Cloud Build target) and
# start-hub.sh (service-account key auto-discovery hint).
PROJECT_ID="your-gcp-project-id"

# Postgres connection string for the Hub storage substrate. Consumed by
# start-hub.sh. Local dev: see docs/operator/hub-storage-substrate-local-dev.md.
POSTGRES_CONNECTION_STRING="postgres://hub:hub@localhost:5432/hub"

# ── Optional ───────────────────────────────────────────────────────────

# GCS state bucket name. Consumed by start-hub.sh; defaults to
# ois-relay-hub-state when unset.
STATE_BUCKET_NAME="ois-relay-hub-state"

# Cloud Build region. Consumed by build-hub.sh; defaults to
# australia-southeast1 when unset. (GCP_REGION env-var still overrides.)
REGION="australia-southeast1"

# repo-event-bridge (mission-52 T3). Token absent → the bridge no-ops at
# Hub startup. Repos are comma-separated owner/name.
OIS_GH_API_TOKEN=""
OIS_REPO_EVENT_BRIDGE_REPOS=""
OIS_REPO_EVENT_BRIDGE_CADENCE_S="30"
OIS_REPO_EVENT_BRIDGE_RATE_BUDGET_PCT="0.8"
