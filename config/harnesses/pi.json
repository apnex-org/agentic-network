{
  "harness": "pi",
  "_why": "pi harness: OIS acquires and verifies the exact npm artifact, seeds from that root, and passes its canonical dist/index.js path through -e. Pi-native npm acquisition is forbidden.",
  "exec": [
    "pi",
    "-e",
    "{piPluginSpec}",
    "--provider",
    "{piProvider}",
    "--model",
    "{piModel}",
    "--continue"
  ],
  "piPluginSpec": "@apnex/pi-plugin@0.1.9",
  "piKeepRecentTokens": 24000,
  "envTemplate": {
    "OIS_EAGER_SESSION_CLAIM": "{eagerFlag}",
    "HUB_LLM_MODEL": "{hubModelTag}",
    "OIS_HUB_ROLE": "{role}"
  },
  "renders": [
    "adapter-config"
  ],
  "configDirTemplate": "~/.config/apnex-agents/{agent}.pi",
  "piSettings": {
    "theme": "dark",
    "defaultProvider": "openai-codex",
    "defaultModel": "gpt-5.6-sol",
    "defaultThinkingLevel": "xhigh",
    "terminal": {
      "showTerminalProgress": true
    },
    "transport": "auto",
    "compaction": {
      "enabled": true,
      "reserveTokens": 32000,
      "keepRecentTokens": 24000
    },
    "packages": []
  },
  "piModels": {
    "providers": {
      "openai-codex": {
        "modelOverrides": {
          "gpt-5.6-sol": {
            "contextWindow": 400000
          }
        }
      }
    }
  },
  "pluginVersion": "0.1.9",
  "pluginIntegrity": "PENDING_PUBLICATION",
  "publicationAttestation": "PENDING_PUBLICATION"
}
