{
  "harness": "pi",
  "_why": "pi harness: hub plugin loaded ephemerally from npm each launch, pinned via piPluginSpec (the -e flag overrides any package pin in settings). Per-seat PI_CODING_AGENT_DIR/settings.json and models.json are rendered from this OIS config source; do not rely on ~/.pi/agent or workspace .pi fallback for seat-critical Pi policy.",
  "exec": [
    "pi",
    "-e",
    "{piPluginSpec}",
    "--provider",
    "{piProvider}",
    "--model",
    "{piModel}",
    "--continue"
  ],
  "piPluginSpec": "npm:@apnex/pi-plugin@0.1.6",
  "piKeepRecentTokens": 24000,
  "envTemplate": {
    "OIS_EAGER_SESSION_CLAIM": "{eagerFlag}",
    "HUB_LLM_MODEL": "{hubModelTag}",
    "OIS_HUB_ROLE": "{role}"
  },
  "renders": [
    "adapter-config"
  ],
  "configDirTemplate": "~/.config/apnex-agents/{agent}.pi",
  "piSettings": {
    "theme": "dark",
    "defaultProvider": "openai-codex",
    "defaultModel": "gpt-5.5",
    "defaultThinkingLevel": "xhigh",
    "terminal": {
      "showTerminalProgress": true
    },
    "transport": "auto",
    "compaction": {
      "enabled": true,
      "reserveTokens": 32000,
      "keepRecentTokens": 24000
    },
    "packages": [
      "npm:pi-tool-display",
      "npm:pi-web-access"
    ]
  },
  "piModels": {
    "providers": {
      "openai-codex": {
        "modelOverrides": {
          "gpt-5.5": {
            "contextWindow": 400000
          }
        }
      }
    }
  }
}
